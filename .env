# ═════════════════════════════════════════════════════════
# CloudGuard — Environment Variables
# Copy to .env and fill in your values
# ═════════════════════════════════════════════════════════

# App
DEBUG=false

# Database (auto-set in docker-compose, override for local dev)
# DATABASE_URL=postgresql+asyncpg://cloudguard:cloudguard@localhost:5432/cloudguard

# Redis (auto-set in docker-compose)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI — Google Gemini
GEMINI_API_KEY=AIzaSyC53Qv2kZYOczXNZ_hND0NS17PqEesyBPw

# Alerts — Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=cloudguard@example.com
ALERT_EMAIL_TO=

# Alerts — Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
